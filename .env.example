# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated allowed origins for CORS (your Static Web App URL in prod)
CORS_ORIGINS=http://localhost:5173

# ── Azure SQL Database (Sequelize / tedious) ────────────
# In production, pull these from Azure Key Vault — do NOT commit real values.
DB_HOST=<server>.database.windows.net
DB_PORT=1433
DB_NAME=tolet
DB_USER=<user>
DB_PASSWORD=<password>

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# ── Logger ──────────────────────────────────────────────
LOG_LEVEL=info
SERVICE_NAME=tolet-backend

# ── Azure Blob Storage (Winston log sink) ──────────────
# Logs are written directly to Append Blobs — no local log files are created.
# Layout: <container>/{error,warn,info}/YYYY-MM-DD.log, rolling to
# YYYY-MM-DD-001.log, -002.log, ... once a day's file passes 50MB.
AZURE_STORAGE_CONNECTION_STRING=<storage-account-connection-string>
AZURE_LOG_CONTAINER=app-logs
