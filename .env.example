# ── Server ──────────────────────────────────────────────
PORT={{PORT}}
NODE_ENV={{NODE_ENV}}
# Comma-separated allowed origins for CORS (your Static Web App URL in prod)
CORS_ORIGINS={{CORS_ORIGINS}}

# ── Azure SQL Database (Sequelize / tedious) ────────────
# In production, pull these from Azure Key Vault — do NOT commit real values.
DB_HOST={{DB_HOST}}
DB_PORT={{DB_PORT}}
DB_NAME={{DB_NAME}}
DB_USER={{DB_USER}}
DB_PASSWORD={{DB_PASSWORD}}

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET={{JWT_ACCESS_SECRET}}
JWT_ACCESS_TTL={{JWT_ACCESS_TTL}}
JWT_REFRESH_SECRET={{JWT_REFRESH_SECRET}}
JWT_REFRESH_TTL={{JWT_REFRESH_TTL}}

# ── Logger ──────────────────────────────────────────────
LOG_LEVEL={{LOG_LEVEL}}
SERVICE_NAME={{SERVICE_NAME}}

# ── Azure Blob Storage (Winston log sink) ──────────────
# Logs are written directly to Append Blobs — no local log files are created.
# Layout: <container>/{error,warn,info}/YYYY-MM-DD.log, rolling to
# YYYY-MM-DD-001.log, -002.log, ... once a day's file passes 50MB.
AZURE_STORAGE_CONNECTION_STRING={{AZURE_STORAGE_CONNECTION_STRING}}
AZURE_LOG_CONTAINER={{AZURE_LOG_CONTAINER}}
